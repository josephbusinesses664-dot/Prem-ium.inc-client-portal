1?source=sharing\",\n    \"deliveryMethod\": \"http://purl.org/goodrelations/v1#DeliveryModeOwnFleet\"\n  }\n}\n</script>\n<!-- Meta Pixel -->\n<script>\n(function(){\n  var META_PIXEL_ID='1400137061960739'; /* <-- paste your Meta Pixel ID here (from Meta Events Manager). Stays OFF until a real ID is set. */\n  if(!/^\\d{6,}$/.test(META_PIXEL_ID))return;\n  !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,document,'script','https://connect.facebook.net/en_US/fbevents.js');\n  fbq('init',META_PIXEL_ID);\n  fbq('track','PageView');\n  /* Count taps on the Swiggy/Zomato order buttons as Lead conversions */\n  window.addEventListener('DOMContentLoaded',function(){\n    document.querySelectorAll('a[href*=\"swiggy.com\"],a[href*=\"zomato\"]').forEach(function(a){\n      a.addEventListener('click',function(){try{fbq('track','Lead');}catch(e){}});\n    });\n  });\n})();\n</script>\n<!-- End Meta Pixel -->\n</head>\n<body>\n<noscript><img height=\"1\" width=\"1\" style=\"display:none\" alt=\"\" src=\"https://www.facebook.com/tr?id=1400137061960739&ev=PageView&noscript=1\"/></noscript>\n\n\n<nav>\n  <a href=\"index.html\" class=\"logo\">Que<span>Snack</span></a>\n  <ul class=\"nav-links\">\n    <li class=\"hide-mobile\"><a href=\"index.html\">Home</a></li>\n    <li><a href=\"menu.html\" class=\"active\">Menu</a></li>\n    <li class=\"hide-mobile\"><a href=\"index.html#visit\">Find Us</a></li>\n    <li><a href=\"https://www.swiggy.com/menu/1402418?source=sharing\" target=\"_blank\" rel=\"noopener\" class=\"nav-order\">Order Now</a></li>\n  </ul>\n</nav>\n\n<div class=\"menu-hero\">\n  <div class=\"eyebrow\">Our Menu</div>\n  <h1 class=\"section-title\" style=\"font-size:clamp(2.2rem,5vw,3.4rem)\">Fresh off the griddle.</h1>\n  <p class=\"section-sub\" style=\"margin:0 auto\">Everything made to order. Deal prices live on Swiggy right now.</p>\n</div>\n\n<div class=\"menu-note\">\n  <strong>₹49 deals</strong> on select waffles &amp; pancakes, plus <strong>FLAT ₹100 off</strong> with code <strong>FLATDEAL</strong> —\n  offers apply when you <a href=\"https://www.swiggy.com/menu/1402418?source=sharing\" target=\"_blank\" rel=\"noopener\">order on Swiggy</a>.\n</div>\n\n<!-- ── Waffles & Pancakes ── -->\n<section class=\"menu-section\">\n  <div class=\"container\">\n    <h2 class=\"menu-cat\">Waffles &amp; Pancakes <span class=\"menu-cat-count\">5 items</span></h2>\n    <div class=\"dish-grid\">\n      <div class=\"dish-card\" data-reveal=\"\">\n        <img class=\"dish-img\" src=\"https://images.unsplash.com/photo-1562376552-0d160a2f238d?auto=format&amp;fit=crop&amp;w=600&amp;q=70\" alt=\"Blueberry Waffle\" loading=\"lazy\">\n        <div class=\"dish-body\">\n          <div class=\"dish-top\"><span class=\"veg-dot\" title=\"Veg\"></span><span class=\"dish-name\">Blueberry Waffle</span><span class=\"bestseller-chip\">Bestseller</span></div>\n          <p class=\"dish-desc\">A breakfast staple — golden, crispy exterior and a fluffy, tender interior studded with warm, bursting blueberries.</p>\n          <div class=\"dish-price-row\"><span class=\"dish-price\">₹49</span><span class=\"dish-strike\">₹219</span><span class=\"deal-chip\">DEAL</span></div>\n        </div>\n      </div>\n      <div class=\"dish-card\" data-reveal=\"\">\n        <img class=\"dish-img\" src=\"https://images.unsplash.com/photo-1598214886806-c87b84b7078b?auto=format&amp;fit=crop&amp;w=600&amp;q=70\" alt=\"Choco Waffle\" loading=\"lazy\">\n        <div class=\"dish-body\">\n          <div class=\"dish-top\"><span class=\"veg-dot\" title=\"Veg\"></span><span class=\"dish-name\">Choco Waffle</span></div>\n          <p class=\"dish-desc\">Eggless. A rich, indulgent take on the classic — deep cocoa flavour, crisp outside, fluffy inside.</p>\n          <div class=\"dish-price-row\"><span class=\"dish-price\">₹219</span></div>\n        </div>\n      </div>\n      <div class=\"dish-card\" data-reveal=\"\">\n        <img class=\"dish-img\" src=\"https://images.unsplash.com/photo-1568051243851-f9b136146e97?auto=format&amp;fit=crop&amp;w=600&amp;q=70\" alt=\"Nutella Waffle\" loading=\"lazy\">\n        <div class=\"dish-body\">\n          <div class=\"dish-top\"><span class=\"veg-dot\" title=\"Veg\"></span><span class=\"dish-name\">Nutella Waffle</span></div>\n          <p class=\"dish-desc\">Eggless. Warm and crispy outside, soft inside — generously loaded with creamy Nutella hazelnut spread.</p>\n          <div class=\"dish-price-row\"><span class=\"dish-price\">₹269</span></div>\n        </div>\n      </div>\n      <div class=\"dish-card\" data-reveal=\"\">\n        <img class=\"dish-img\" src=\"https://images.unsplash.com/photo-1528207776546-365bb710ee93?auto=format&amp;fit=crop&amp;w=600&amp;q=70\" alt=\"Classic Pancake\" loading=\"lazy\">\n        <div class=\"dish-body\">\n          <div class=\"dish-top\"><span class=\"veg-dot\" title=\"Veg\"></span><span class=\"dish-name\">Classic Pancake</span></div>\n          <p class=\"dish-desc\">Soft, fluffy and airy with a lightly browned, slightly crisp exterior. The classic, done right.</p>\n          <div class=\"dish-price-row\"><span class=\"dish-price\">₹49</span><span class=\"dish-strike\">₹219</span><span class=\"deal-chip\">DEAL</span></div>\n        </div>\n      </div>\n      <div class=\"dish-card\" data-reveal=\"\">\n        <img class=\"dish-img\" src=\"https://images.unsplash.com/photo-1567620905732-2d1ec7ab7445?auto=format&amp;fit=crop&amp;w=600&amp;q=70\" alt=\"Chocolate Pancake\" loading=\"lazy\">\n        <div class=\"dish-body\">\n          <div class=\"dish-top\"><span class=\"veg-dot\" title=\"Veg\"></span><span class=\"dish-name\">Chocolate Pancake</span></div>\n          <p class=\"dish-desc\">Eggless. A rich, decadent twist on classic pancakes, finished with chocolate syrup.</p>\n          <div class=\"dish-price-row\"><span class=\"dish-price\">₹219</span></div>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- ── Snacks & Burgers ── -->\n<section class=\"menu-section\">\n  <div class=\"container\">\n    <h2 class=\"menu-cat\">Snacks &amp; Burgers <span class=\"menu-cat-count\">customer favourites</span></h2>\n    <div class=\"dish-grid\">\n      <div class=\"dish-card\" data-reveal=\"\">\n        <img class=\"dish-img\" src=\"https://images.unsplash.com/photo-1562967914-608f82629710?auto=format&amp;fit=crop&amp;w=600&amp;q=70\" alt=\"Chicken Pop Corn\" loading=\"lazy\">\n        <div class=\"dish-body\">\n          <div class=\"dish-top\"><span class=\"dish-name\">Chicken Pop Corn</span><span class=\"bestseller-chip\">Popular</span></div>\n          <p class=\"dish-desc\">Bite-sized, crunchy and juicy — prepared fresh with quality ingredients. One of our most-ordered dishes.</p>\n          <div class=\"dish-price-row\"><a href=\"https://www.swiggy.com/menu/1330261?source=sharing\" target=\"_blank\" rel=\"noopener\" style=\"color:var(--berry);font-weight:700;font-size:14px;text-decoration:none\">Price on Swiggy →</a></div>\n        </div>\n      </div>\n      <div class=\"dish-card\" data-reveal=\"\">\n        <img class=\"dish-img\" src=\"https://images.unsplash.com/photo-1568901346375-23c9450c58cd?auto=format&amp;fit=crop&amp;w=600&amp;q=70\" alt=\"Peri Peri Veg Spicy Burger\" loading=\"lazy\">\n        <div class=\"dish-body\">\n          <div class=\"dish-top\"><span class=\"veg-dot\" title=\"Veg\"></span><span class=\"dish-name\">Peri Peri Veg Spicy Burger</span><span class=\"bestseller-chip\">Popular</span></div>\n          <p class=\"dish-desc\">A fiery, flavour-packed veg burger with our peri peri kick — for those who like it spicy.</p>\n          <div class=\"dish-price-row\"><a href=\"https://www.swiggy.com/menu/1402418?source=sharing\" target=\"_blank\" rel=\"noopener\" style=\"color:var(--berry);font-weight:700;font-size:14px;text-decoration:none\">Price on Swiggy →</a></div>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- ── More ── -->\n<section class=\"menu-section\" style=\"padding-bottom:72px\">\n  <div class=\"container\">\n    <h2 class=\"menu-cat\">And lots more…</h2>\n    <p class=\"section-sub\">Mexican-style fast food, rice varieties, more snacks and seasonal specials — the complete live menu with today's prices and offers is on our delivery pages.</p>\n    <div style=\"display:flex;gap:14px;flex-wrap:wrap;margin-top:26px\">\n      <a class=\"btn btn-swiggy\" href=\"https://www.swiggy.com/menu/1402418?source=sharing\" target=\"_blank\" rel=\"noopener\">Full Menu on Swiggy</a>\n      <a class=\"btn btn-zomato\" href=\"https://zomato.onelink.me/xqzv/zh776qji\" target=\"_blank\" rel=\"noopener\">Full Menu on Zomato</a>\n    </div>\n  </div>\n</section>\n\n<!-- ── Footer ── -->\n<footer>\n  <div class=\"footer-inner\">\n    <div>\n      <a href=\"index.html\" class=\"logo\">Que<span style=\"color:#ff7a9c\">Snack</span></a>\n      <p style=\"font-size:13.5px;margin-top:8px;max-width:280px\">Waffles, pancakes &amp; snacks — made fresh in Dr. A. S. Rao Nagar, Hyderabad.</p>\n    </div>\n    <ul class=\"footer-links\">\n      <li><a href=\"index.html\">Home</a></li>\n      <li><a href=\"https://www.swiggy.com/menu/1402418?source=sharing\" target=\"_blank\" rel=\"noopener\">Swiggy</a></li>\n      <li><a href=\"https://zomato.onelink.me/xqzv/zh776qji\" target=\"_blank\" rel=\"noopener\">Zomato</a></li>\n      <li><a href=\"https://www.instagram.com/quesnack.online/\" target=\"_blank\" rel=\"noopener\">Instagram</a></li>\n    </ul>\n  </div>\n  <div class=\"footer-bottom\">\n    <span>© 2026 QueSnack. All rights reserved. Prices set by the restaurant and may vary on delivery platforms.</span>\n    <span>FSSAI Lic. No. 23626033000544</span>\n  </div>\n  <div class=\"made-by\"><a href=\"https://prem-ium-inc.onrender.com\" target=\"_blank\" rel=\"noopener\">made by prem-ium.inc</a></div>\n</footer>\n\n<script>\nconst obs = new IntersectionObserver(es => es.forEach(e => {\n  if (e.isIntersecting) { e.target.classList.add('in'); obs.unobserve(e.target); }\n}), { threshold: .15 });\ndocument.querySelectorAll('[data-reveal]').forEach(el => obs.observe(el));\n</script>\n\n\n</body></html>",
